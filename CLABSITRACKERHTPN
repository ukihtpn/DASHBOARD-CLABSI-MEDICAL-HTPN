<script>
const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRhbKJs0H-N4AInALV71BNmmjXR2lUzWGuqu2gjGxz_YnbD4XYq4Mjpu0_l84PTc89AXkxw0Y7zZDnH/pub?gid=77045550&single=true&output=csv";
const WARDS = ["WAD 1","WAD 2","WAD 3","WAD 6"];
const Q_COLORS = ['#6366f1','#8b5cf6','#ec4899','#f97316'];
let trendChart = null, compChart = null;

function parseCSV(text) {
  return text.split(/\r?\n/).map(line => {
    const cells = []; let cur = '', inQ = false;
    for (const ch of line) {
      if (ch === '"') { inQ = !inQ; }
      else if (ch === ',' && !inQ) { cells.push(cur.trim()); cur = ''; }
      else { cur += ch; }
    }
    cells.push(cur.trim());
    return cells;
  });
}

async function fetchData() {
  setRefreshSpin(true);
  try {
    const res  = await fetch(CSV_URL + '&t=' + Date.now());
    const text = await res.text();
    const rows = parseCSV(text);

    document.getElementById('last-updated').textContent = (rows[4]?.[0] || '').replace('\r','') || 'N/A';

    const kR = rows[6] || [];
    document.getElementById('kpi-cases').textContent = kR[0] || '—';
    document.getElementById('kpi-days').textContent  = kR[4] || '—';
    const rt = parseFloat(kR[8]);
    document.getElementById('kpi-rate').textContent  = isNaN(rt) ? '—' : rt.toFixed(2);

    const monthly = [];
    for (let i = 11; i <= 22 && i < rows.length; i++) {
      const r = rows[i];
      if (!r[0] || r[0].toLowerCase().includes('jumlah')) break;
      const k = parseFloat(r[6]);
      monthly.push({
        bulan: r[0].replace('\r',''),
        kes:   parseInt(r[2])  || 0,
        days:  parseInt(r[4])  || 0,
        kadar: isNaN(k) ? 0 : +k.toFixed(2),
      });
    }

    const wardHIdx = rows.findIndex(r => r[0] && r[0].toUpperCase().includes('WARD 1'));
    const wardVals = wardHIdx >= 0 ? (rows[wardHIdx + 1] || []) : [];
    const wardDays  = [wardVals[0], wardVals[3], wardVals[6], wardVals[9]];

    const dateEventIdx = rows.findIndex(r => r[0] && r[0].toUpperCase().includes('DATE') && r[0].toUpperCase().includes('LAST EVENT'));
    const dateRow = dateEventIdx >= 0 ? rows[dateEventIdx] : [];
    const wardDates = [dateRow[1], dateRow[4], dateRow[7], dateRow[10]];

    const qLabels  = ['Q1','Q2','Q3','Q4'];
    const qPeriods = ['Jan – Mac','Apr – Jun','Jul – Sep','Okt – Dis'];
    const qResults = {};

    qLabels.forEach(q => {
      qResults[q] = {};
      const qRowIdx = rows.findIndex(r =>
        r.some(c => c && c.includes(q) &&
          (c.includes('Jan') || c.includes('Apr') || c.includes('Jul') || c.includes('Okt'))
        )
      );
      if (qRowIdx < 0) return;

      for (let i = qRowIdx + 1; i < qRowIdx + 12 && i < rows.length; i++) {
        const r = rows[i];
        if (!r || !r[0]) continue;
        const w = WARDS.find(w => r[0].replace('\r','').toUpperCase() === w);
        if (w) {
          const ov = parseFloat(r[10]);
          qResults[q][w] = isNaN(ov) ? 0 : ov;
        }
      }
    });

    renderTrend(monthly);
    renderWards(wardDays, wardDates);
    renderQSummary(qResults, qPeriods);
    renderCompChart(qResults);
    showApp();

  } catch(e) {
    console.error('fetchData error:', e);
    showApp();
  }
  setRefreshSpin(false);
}

function renderTrend(monthly) {
  if (trendChart) trendChart.destroy();
  const ctx = document.getElementById('trend-chart').getContext('2d');
  const labels = monthly.map(d => d.bulan);
  const values = monthly.map(d => d.kadar);

  Chart.register(ChartDataLabels);

  trendChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'CLABSI Rate',
        data: values,
        borderColor: '#f59e0b',
        backgroundColor: 'rgba(245,158,11,.08)',
        borderWidth: 8,
        pointBackgroundColor: values.map(v => v > 0 && v >= 5 ? '#ef4444' : '#f59e0b'),
        pointBorderColor: '#ffffff',
        pointBorderWidth: 4,
        pointRadius: 10,
        pointHoverRadius: 13,
        tension: 0.4,
        fill: true,
        datalabels: {
          display: ctx => values[ctx.dataIndex] > 0,
          formatter: v => v.toFixed(2),
          color: ctx => values[ctx.dataIndex] >= 5 ? '#b91c1c' : '#92400e',
          font: { size: 13, weight: '900', family: 'Inter' },
          anchor: 'end',
          align: 'top',
          offset: 8,
          padding: { top: 4, bottom: 4, left: 6, right: 6 },
          backgroundColor: ctx => values[ctx.dataIndex] >= 5
            ? 'rgba(254,226,226,0.9)'
            : 'rgba(254,243,199,0.9)',
          borderRadius: 8,
          borderWidth: 1.5,
          borderColor: ctx => values[ctx.dataIndex] >= 5 ? '#fca5a5' : '#fcd34d',
        }
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      layout: { padding: { top: 40, right: 20 } },
      plugins: {
        legend: { display: false },
        datalabels: {},
        tooltip: {
          backgroundColor: '#0f172a',
          titleColor: '#f1f5f9',
          bodyColor: '#94a3b8',
          padding: 14, cornerRadius: 16,
          callbacks: {
            title: c => c[0].label,
            label: c => {
              const v = c.parsed.y;
              if (v === 0) return ' Tiada Data';
              return ` Rate: ${v.toFixed(2)} / 1000 catheter days`;
            },
            afterLabel: c => {
              const v = c.parsed.y;
              if (v === 0) return '';
              return v >= 5 ? ' ⚠️ Melebihi Global Average!' : ' ✅ Di bawah Global Average';
            }
          }
        },
        annotation: {
          annotations: {
            stdLine: {
              type: 'line', yMin: 5, yMax: 5,
              borderColor: '#ef4444', borderWidth: 2, borderDash: [6,4],
              label: {
                content: 'GLOBAL AVERAGE < 5.0',
                display: true, position: 'end',
                color: '#ef4444', font: { size: 11, weight: '900' },
                backgroundColor: 'transparent', yAdjust: -14
              }
            }
          }
        }
      },
      scales: {
        x: { grid:{display:false}, ticks:{color:'#94a3b8',font:{size:12,weight:'900'}}, border:{display:false} },
        y: { grid:{color:'#f1f5f9'}, ticks:{color:'#94a3b8',font:{size:11,weight:'700'}}, border:{display:false}, min:0 }
      }
    }
  });
}

function renderWards(days, dates) {
  const names = ['Wad 1','Wad 2','Wad 3','Wad 6'];
  const grid  = document.getElementById('ward-grid');
  const dgrid = document.getElementById('ward-date-grid');
  grid.innerHTML = ''; dgrid.innerHTML = '';

  names.forEach((name, i) => {
    const val = (days[i] || '').replace('\r','') || '—';
    const d = document.createElement('div');
    d.className = 'ward-card';
    d.innerHTML = `
      <p style="font-size:24px;font-weight:900;color:#0f172a;letter-spacing:-1px;text-transform:uppercase;">${name}</p>
      <p style="font-size:76px;font-weight:900;color:#0f172a;line-height:1;margin:12px 0;filter:drop-shadow(0 2px 4px rgba(0,0,0,.15));">${val}</p>
      <p style="font-size:11px;font-weight:900;border-top:1px solid rgba(0,0,0,.1);padding-top:12px;text-transform:uppercase;letter-spacing:.2em;color:#1e293b;font-style:italic;">Days Case Free</p>`;
    grid.appendChild(d);

    const dateVal = (dates[i] || '').replace('\r','');
    if (dateVal) {
      const dd = document.createElement('div');
      dd.style.cssText = 'background:white;border-radius:16px;padding:14px;text-align:center;border:1px solid #e2e8f0;';
      dd.innerHTML = `<p style="font-size:10px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px;">Date Last Event</p>
        <p style="font-size:14px;font-weight:900;color:#0f172a;">${dateVal}</p>`;
      dgrid.appendChild(dd);
    }
  });
}

function renderQSummary(qResults, periods) {
  const bgMap = {Q1:'#6366f1',Q2:'#8b5cf6',Q3:'#ec4899',Q4:'#f97316'};
  const grid  = document.getElementById('q-summary-grid');
  grid.innerHTML = '';

  ['Q1','Q2','Q3','Q4'].forEach((q, qi) => {
    const wards = qResults[q] || {};
    const vals  = WARDS.map(w => wards[w] || 0).filter(v => v > 0);
    const avg   = vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;
    const good  = avg !== null && avg >= 80;

    const div = document.createElement('div');
    div.style.cssText = 'background:white;border:2px solid #e2e8f0;border-radius:20px;overflow:hidden;';
    div.innerHTML = `
      <div style="background:${bgMap[q]};padding:14px 18px;">
        <div style="font-size:18px;font-weight:900;color:white;">${q}</div>
        <div style="font-size:11px;color:rgba(255,255,255,.75);font-weight:600;">${periods[qi]}</div>
      </div>
      <div style="padding:14px 18px;">
        ${WARDS.map(w => {
          const pct = wards[w] || 0;
          const ok  = pct >= 80;
          return `<div class="q-row">
            <span style="font-weight:700;color:#475569;">${w}</span>
            <span style="font-weight:900;color:${pct>0?(ok?'#16a34a':'#dc2626'):'#94a3b8'};">
              ${pct>0 ? pct.toFixed(1)+'% '+(ok?'✅':'⚠️') : '—'}
            </span>
          </div>`;
        }).join('')}
        <div style="padding-top:10px;margin-top:8px;border-top:2px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;font-weight:700;color:#64748b;">Purata ${q}</span>
          <span style="font-size:18px;font-weight:900;color:${avg!==null?(good?'#16a34a':'#dc2626'):'#94a3b8'};">
            ${avg !== null ? avg.toFixed(1)+'%' : '—'}
          </span>
        </div>
      </div>`;
    grid.appendChild(div);
  });
}

function renderCompChart(qResults) {
  if (compChart) compChart.destroy();
  const ctx = document.getElementById('compliance-chart').getContext('2d');
  compChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: WARDS,
      datasets: ['Q1','Q2','Q3','Q4'].map((q,i) => ({
        label: q,
        data: WARDS.map(w => (qResults[q]||{})[w] || 0),
        backgroundColor: Q_COLORS[i] + 'bb',
        borderColor: Q_COLORS[i],
        borderWidth: 2,
        borderRadius: 6,
        borderSkipped: false,
      }))
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { labels:{color:'#64748b',font:{size:11,weight:'900'},padding:20,usePointStyle:true,pointStyle:'circle'} },
        tooltip: {
          backgroundColor:'#0f172a', titleColor:'#f1f5f9', bodyColor:'#94a3b8',
          padding:14, cornerRadius:16,
          callbacks:{ label: c => ` ${c.dataset.label}: ${c.parsed.y>0?c.parsed.y.toFixed(1)+'%':'Tiada Data'}` }
        }
      },
      scales: {
        x: { grid:{display:false}, ticks:{color:'#64748b',font:{size:13,weight:'900'}}, border:{display:false} },
        y: { min:0, max:100, grid:{color:'#f1f5f9'}, ticks:{color:'#94a3b8',font:{size:11,weight:'700'},callback:v=>v+'%'}, border:{display:false} }
      }
    }
  });
}

function showApp() {
  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
}
function setRefreshSpin(on) {
  document.getElementById('refresh-icon').classList[on?'add':'remove']('spin');
}
function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  sb.style.display = sb.style.display === 'none' ? 'flex' : 'none';
}

fetchData();
</script>
</body>
</html>
